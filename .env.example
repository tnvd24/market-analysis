# Copy to .env. .env is gitignored; this template is committed.
#
# You do NOT need to fill anything in to run the system. Prices, corporate actions and
# filings all come from NSE, which needs no credentials. A fresh clone can run the whole
# ingest -> indicators -> research pack chain with this file left exactly as it is.

# --- Optional: Upstox news feed -----------------------------------------------
# Adds Upstox's news wire on top of NSE's corporate filings. Everything else works
# without it. Read-only Analytics Token: Upstox -> Developer Apps.
UPSTOX_ACCESS_TOKEN=

# --- Storage ------------------------------------------------------------------
# duckdb (local, free) | bigquery (prod)
STORAGE_BACKEND=duckdb
DUCKDB_PATH=./data/asr.duckdb
# Only used when STORAGE_BACKEND=bigquery
GCP_PROJECT=
BQ_DATASET=asr

# There is no ANTHROPIC_API_KEY, on purpose: no model touches the data. The qualitative
# read happens by pasting a research pack into Claude on your subscription.
# See prompts/analysis.md and docs/decisions.md.
