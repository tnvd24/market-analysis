# Copy to .env and fill in. .env is gitignored; this template is committed.

# --- Upstox (research-only market data) ---
# Analytics Token is preferred: 1-year, read-only. Upstox → Developer Apps.
UPSTOX_ACCESS_TOKEN=
# Only needed if you run the OAuth handshake yourself instead of the Analytics Token.
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8080/callback

# --- Anthropic (needed from Phase 4 onward) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Storage ---
# duckdb (local, free) | bigquery (prod)
STORAGE_BACKEND=duckdb
DUCKDB_PATH=./data/asr.duckdb
# Only used when STORAGE_BACKEND=bigquery
GCP_PROJECT=
BQ_DATASET=asr
